{
  "name": "monorepo-course",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "packageManager": "npm@10.8.2",
  "scripts": {
    "build": "turbo run build",
    "build:clean": "tsc -b --clean",
    "build:tsc": "tsc -b",
    "dev:shared": "npm run dev -w @app/shared-utils",
    "dev:api": "npm run dev -w @app/api-client",
    "dev:auth": "npm run dev -w auth-service",
    "dev:orders": "npm run dev -w orders-service",
    "dev:payments": "npm run dev -w payments-service",
    "dev": "run-p dev:*",
    "start:auth": "npm run start -w auth-service",
    "start:orders": "npm run start -w orders-service",
    "start:payments": "npm run start -w payments-service",
    "start": "run-p start:*",
    "lint": "eslint .",
    "test": "turbo run test",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": "true",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "concurrently": "^10.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  }
}
